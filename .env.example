APP_ENV=development
SECRET_KEY=change-me-with-at-least-32-random-characters
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
# PostgreSQL chạy trong Docker Compose
POSTGRES_DB=rag_cic
POSTGRES_USER=rag_cic
POSTGRES_PASSWORD=rag_cic_dev_password
DATABASE_URL=postgresql+asyncpg://rag_cic:rag_cic_dev_password@localhost:5432/rag_cic
REDIS_URL=redis://redis:6379/0
BACKEND_CORS_ORIGINS=["http://localhost:3000"]
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-minio
MINIO_ENDPOINT=minio:9000

# LLM Providers Configuration
LLM_PROVIDER=gemini
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_DIMENSIONS=768
GEMINI_EMBEDDING_INTERVAL_SECONDS=3
GEMINI_EMBEDDING_MAX_RETRIES=100

# Google Sheets & Drive configs
GOOGLE_SERVICE_ACCOUNT_FILE=/app/secrets/google-service-account.json
GOOGLE_SERVICE_ACCOUNT_HOST_FILE=./secrets/google-service-account.json
GOOGLE_SPREADSHEET_ID=
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_SHEET_RANGE=
GOOGLE_WORKSHEET_NAME=1. Luật Xây dựng
GOOGLE_PRODUCT_SPREADSHEET_ID=
GOOGLE_PRODUCT_WORKSHEET_NAME=Trang tính1
GOOGLE_SYNC_ENABLED=false
ENABLED_FEATURES=["category_management","document_reindex_ui","conversation_history","rag_reranker","human_handoff","lead_management","google_sync","advanced_dashboard"]
GOOGLE_SYNC_INTERVAL_SECONDS=60
PRODUCT_CHROMA_COLLECTION=products
CUSTOMER_LEADS_EXCEL_PATH=data/customer_leads.xlsx

# RAG & validation configurations
EMBEDDING_BATCH_SIZE=1
RAG_DOCUMENT_CANDIDATES=12
RAG_VECTOR_CANDIDATES=30
RAG_KEYWORD_CANDIDATES=30
RAG_FINAL_CHUNKS=8
RAG_MAX_CONTEXT_CHARS=24000
PRODUCT_MAX_SEMANTIC_DISTANCE=0.65
VIETNAM_MOBILE_PREFIXES=03,05,07,08,09
REJECT_DEMO_PHONES=false
SEED_SAMPLE_DOCUMENTS=false
ANONYMIZED_TELEMETRY=False

SENTRY_DSN=
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!
